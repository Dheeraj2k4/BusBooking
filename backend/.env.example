# --- App ---
DATABASE_URL=sqlite:///./bus_ticketing.db

# --- Auth ---
# Generate a strong random value for production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- AI search (Groq) ---
# Groq has an OpenAI-compatible API. Leave GROQ_API_KEY empty to use the
# rule-based fallback parser only. Get a free key at https://console.groq.com
# Other valid models: openai/gpt-oss-20b, llama-3.1-8b-instant
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173
